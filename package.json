{
  "name": "ark-floating-scroll",
  "version": "1.1.0",
  "description": "A high-performance virtualized list component for React that renders only visible items",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "jest",
    "demo": "vite examples",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "react",
    "virtual-list",
    "virtualized",
    "scroll",
    "performance",
    "windowing"
  ],
  "author": "Annup Raj Kapur",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AnnupKapur/ark-floating-scroll.git"
  },
  "license": "MIT",
  "peerDependencies": {
    "react": ">=16.8.0",
    "react-dom": ">=16.8.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "ts-jest": "^29.4.6",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  }
}
